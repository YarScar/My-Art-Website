// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Artwork {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  long        String?
  image       String?
  price       Float
  medium      String?
  dimensions  String?
  year        Int?
  sold        Boolean  @default(false)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String?
  message   String
  createdAt DateTime @default(now())
}